#!/bin/bash
# neos-install-identity — configure the installed NeOS system for full live
# parity: a passwordless 'liveuser' that autologins straight into the Plasma
# desktop, exactly like the live ISO.
#
# Invoked by the Calamares `shellprocess@liveuser` step INSIDE the target chroot
# (after pacstrap + overlay + the displaymanager module). It deliberately
# reinstates the live autologin/empty-password posture on the installed disk —
# this is an intentional product decision (kiosk-style live-on-disk), not the
# hardened multi-user model. Keep that trade-off in mind.
set -euo pipefail

USERNAME="liveuser"
GROUPS_LIST="wheel,video,audio,storage,power,input,network,lp,users"

# 1. Create the unprivileged liveuser (idempotent), in the standard desktop
#    groups, with the same zsh shell the rest of NeOS uses.
if ! id "$USERNAME" >/dev/null 2>&1; then
    useradd -m -U -s /bin/zsh -G "$GROUPS_LIST" "$USERNAME"
else
    usermod -aG "$GROUPS_LIST" "$USERNAME" || true
fi

# 2. No password at all (autologin + passwordless sudo => never prompted).
passwd -d "$USERNAME"

# 3. Passwordless sudo for liveuser (mode 0440, as sudo requires).
mkdir -p /etc/sudoers.d
printf '%s ALL=(ALL:ALL) NOPASSWD: ALL\n' "$USERNAME" > /etc/sudoers.d/00-liveuser-nopasswd
chmod 0440 /etc/sudoers.d/00-liveuser-nopasswd

# 4. SDDM autologin into the X11 Plasma session. Re-asserted here because the
#    Calamares displaymanager module clears autologin when no Calamares user
#    exists (we removed the users page), so this must run AFTER it.
mkdir -p /etc/sddm.conf.d
cat > /etc/sddm.conf.d/autologin.conf <<EOF
[Autologin]
User=$USERNAME
Session=plasmax11
EOF
cat > /etc/sddm.conf.d/00-allow-empty-password.conf <<EOF
[Users]
AllowEmptyPassword=true
EOF

# 5. Disable the screen locker for liveuser so an empty password can never lock
#    them out of their own session.
install -d -o "$USERNAME" -g "$USERNAME" "/home/$USERNAME/.config"
cat > "/home/$USERNAME/.config/kscreenlockerrc" <<EOF
[Daemon]
Autolock=false
LockOnResume=false
EOF
chown "$USERNAME:$USERNAME" "/home/$USERNAME/.config/kscreenlockerrc"

# 6. Hostname + graphical boot target (belt-and-suspenders with services-systemd
#    so the system never lands on a text tty1).
echo neos > /etc/hostname
systemctl set-default graphical.target

echo "neos-install-identity: configured passwordless autologin for '$USERNAME'."
