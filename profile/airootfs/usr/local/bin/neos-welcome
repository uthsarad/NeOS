#!/bin/bash
# Installer launcher for NeOS installation media

set -euo pipefail

if pgrep -x calamares >/dev/null 2>&1; then
    exit 0
fi

if command -v kdialog >/dev/null 2>&1; then
    kdialog --icon system-software-install \
        --title "Install NeOS" \
        --passivepopup "Starting the NeOS installer. This temporary session is only installation media." 5 || true
fi

cleanup_xhost() {
    xhost -SI:localuser:root >/dev/null 2>&1 || true
}

trap cleanup_xhost EXIT
xhost +SI:localuser:root >/dev/null 2>&1 || true
sudo calamares
