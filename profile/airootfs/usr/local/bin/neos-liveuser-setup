#!/bin/bash
set -euo pipefail

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

SCRIPT_NAME="${0##*/}"
SCRIPT_NAME="${SCRIPT_NAME//[^a-zA-Z0-9_.-]/}"

_error_handler() {
    local err=$1
    local line=$2
    local cmd="${BASH_COMMAND//[^[:print:]]/}"
    # Palette: Ensure logged error messages are clear and contain actionable steps for users. Use structural visual cues in terminal output for critical failures.
    # Bolt: Ensure trap commands and error logging minimize subshell overhead. Prefer native bash variables over external process calls in error paths.
    printf -- "\n\\e[1m\\e[31m================================================================================\\e[0m\n\\e[1m\\e[31m🚨 [%s] CRITICAL SCRIPT FAILURE\\e[0m\n\\e[1m\\e[31m================================================================================\\e[0m\n\\e[1m\\e[36m💡 DIAGNOSTICS:\\e[0m\n  • Failed Command: \"%s\"\n  • File / Line:    %s:%s\n  • Exit Status:    %s\n\n\\e[1m\\e[36m🔧 ACTIONABLE STEPS:\\e[0m\n  1. Inspect the system journal for detailed logs:\n     \\e[1mjournalctl -t neos-%s -n 50 --no-pager\\e[0m\n  2. Verify system state, permissions, and script configuration.\\e[1m\\e[31m================================================================================\\e[0m\n\n" "$SCRIPT_NAME" "$cmd" "$SCRIPT_NAME" "$line" "$err" "$SCRIPT_NAME" >&2 || true
    logger -t "neos-$SCRIPT_NAME" "CRITICAL: Script failed at line $line (Exit Code $err). Command: \"$cmd\". Please review the system journal." || true
    exit "$err"
}

trap '_error_handler $? $LINENO' ERR

# liveuser is created at image build time by /root/customize_airootfs.sh (uid
# 1000, full group set). This runtime unit only applies live-session state that
# must happen on the booted system.
if ! id "liveuser" &>/dev/null; then
    echo "liveuser missing — customize_airootfs.sh did not run at build time" >&2
    exit 1
fi

echo "%wheel ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/zz-live-wheel
chmod 0440 /etc/sudoers.d/zz-live-wheel

LIVE_USER_HOME="/home/liveuser"
AUTOSTART_DIR="$LIVE_USER_HOME/.config/autostart"

if [ -d "$LIVE_USER_HOME" ]; then
    mkdir -p "$AUTOSTART_DIR"
    mkdir -p "$LIVE_USER_HOME/Desktop"

    if [ -f "$LIVE_USER_HOME/Desktop/welcome-neos.desktop" ]; then
        chmod +x "$LIVE_USER_HOME/Desktop/welcome-neos.desktop"
        # Mark as trusted for KDE Plasma so it doesn't show "untrusted" warning
        if command -v kwriteconfig6 >/dev/null 2>&1; then
            sudo -u liveuser kwriteconfig6 --file "$LIVE_USER_HOME/Desktop/welcome-neos.desktop" --group "Desktop Entry" --key "X-KDE-SubstituteUID" "false" 2>/dev/null || true
        fi
    fi

    # In a VM there is no usable GPU. Plasma on Wayland has NO uncomposited mode,
    # so KWin tries to composite through llvmpipe and the whole session locks up:
    # the desktop paints once but input is never serviced — buttons appear dead.
    # Force the live VM session onto X11 with compositing OFF so KWin runs as a
    # plain, GL-free window manager: snappy and fully clickable on software
    # rendering. Done deterministically here (root, before display-manager) rather
    # than via the plasma env-script, which races KWin startup. Bare metal is left
    # untouched — Wayland and hardware compositing stay available there.
    if [ "$(systemd-detect-virt 2>/dev/null || echo none)" != "none" ]; then
        # Remove the Wayland session so neither autologin nor the SDDM greeter can
        # land on it in a VM. The installed system is pacstrapped fresh, so this
        # only affects the live environment.
        rm -f /usr/share/wayland-sessions/plasma.desktop

        # Fix SDDM autologin: Since we removed the default Wayland session,
        # we must point the autologin target to the X11 session instead.
        if [ -f /etc/sddm.conf.d/autologin.conf ]; then
            sed -i 's/^Session=.*/Session=plasmax11/' /etc/sddm.conf.d/autologin.conf
        fi

        mkdir -p "$LIVE_USER_HOME/.config"
        printf '[Compositing]\nEnabled=false\n' > "$LIVE_USER_HOME/.config/kwinrc"
        printf '[KDE]\nAnimationDurationFactor=0\n' > "$LIVE_USER_HOME/.config/kdeglobals"
    fi

    chown -R liveuser:users "$LIVE_USER_HOME"
fi
