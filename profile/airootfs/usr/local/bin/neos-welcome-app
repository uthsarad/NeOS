#!/usr/bin/env python3
import sys
import os
import subprocess
from PyQt6.QtWidgets import (QApplication, QWidget, QVBoxLayout, QHBoxLayout, 
                             QPushButton, QLabel)
from PyQt6.QtCore import Qt

class NeosWelcome(QWidget):
    def __init__(self):
        super().__init__()
        self.initUI()

    def initUI(self):
        self.setWindowTitle('Welcome to NeOS')
        self.setFixedSize(650, 450)
        self.setStyleSheet("""
            QWidget {
                background-color: #11111b;
                color: #cdd6f4;
                font-family: 'Inter', sans-serif;
            }
            QLabel#title {
                font-size: 36px;
                font-weight: 900;
                color: #cba6f7;
                margin-top: 30px;
            }
            QLabel#subtitle {
                font-size: 16px;
                color: #a6adc8;
                margin-bottom: 40px;
            }
            QPushButton {
                background-color: #1e1e2e;
                border: 2px solid #585b70;
                border-radius: 12px;
                padding: 15px 40px;
                font-size: 18px;
                font-weight: bold;
                color: #cdd6f4;
            }
            QPushButton:hover {
                background-color: #313244;
                border: 2px solid #cba6f7;
                color: #cba6f7;
            }
            QPushButton#primary {
                background-color: #cba6f7;
                border: 2px solid #cba6f7;
                color: #11111b;
            }
            QPushButton#primary:hover {
                background-color: #b4befe;
                border: 2px solid #b4befe;
            }
        """)

        layout = QVBoxLayout()
        layout.setAlignment(Qt.AlignmentFlag.AlignCenter)

        title = QLabel('Welcome to NeOS')
        title.setObjectName('title')
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)
        
        subtitle = QLabel('Hyper-optimized. Blazingly fast. Unapologetically elite.')
        subtitle.setObjectName('subtitle')
        subtitle.setAlignment(Qt.AlignmentFlag.AlignCenter)

        btn_layout = QHBoxLayout()
        btn_layout.setSpacing(30)

        try_btn = QPushButton('Try Live Environment')
        try_btn.setCursor(Qt.CursorShape.PointingHandCursor)
        try_btn.clicked.connect(self.close)

        install_btn = QPushButton('Install NeOS')
        install_btn.setObjectName('primary')
        install_btn.setCursor(Qt.CursorShape.PointingHandCursor)
        install_btn.clicked.connect(self.run_installer)

        btn_layout.addWidget(try_btn)
        btn_layout.addWidget(install_btn)
        btn_layout.setAlignment(Qt.AlignmentFlag.AlignCenter)

        layout.addStretch(1)
        layout.addWidget(title)
        layout.addWidget(subtitle)
        layout.addLayout(btn_layout)
        layout.addStretch(1)

        self.setLayout(layout)

    def run_installer(self):
        subprocess.Popen(['/usr/local/bin/neos-welcome'])
        self.close()

if __name__ == '__main__':
    app = QApplication(sys.argv)
    ex = NeosWelcome()
    ex.show()
    sys.exit(app.exec())
