#!/bin/bash
# neos-pacstrap — NeOS netinstall backend with offline fallback.
#
# Invoked by the Calamares 'pacstrap' step (shellprocess, dontChroot) with the
# target root mount point as $1.
#
# Hybrid install model:
#   ONLINE:  Download fresh packages from internet mirrors (always latest).
#   OFFLINE: Install from the local ISO package repo at /run/archiso/bootmnt/neos/pkg/
#            so the install completes without any network.
#
# The local repo is built by tools/gen-install-repo.sh during ISO creation and
# embedded directly on the ISO at /neos/pkg/. It is accessible at
# /run/archiso/bootmnt/neos/pkg/ when booted from the live ISO.
set -euo pipefail

ROOT="${1:?usage: neos-pacstrap <target-root>}"
PKGLIST="/etc/calamares/neos-packages.txt"
OVERLAY="/etc/calamares/neos-overlay.txt"

log() { echo "neos-pacstrap: $*"; }

if [[ ! -d "$ROOT" ]]; then
    echo "neos-pacstrap: target root '$ROOT' is not a mounted directory" >&2
    exit 1
fi
if [[ ! -f "$PKGLIST" ]]; then
    echo "neos-pacstrap: package list '$PKGLIST' is missing" >&2
    exit 1
fi

# Build the package array (skip comments / blank lines).
mapfile -t PKGS < <(grep -vE '^[[:space:]]*(#|$)' "$PKGLIST")
if [[ ${#PKGS[@]} -eq 0 ]]; then
    echo "neos-pacstrap: package list is empty" >&2
    exit 1
fi

# (1) Entropy: pacstrap -K generates a fresh pacman keyring inside the new root,
# and gpg blocks on /dev/random until the kernel CRNG has enough entropy. On a
# headless VM that can stall for minutes or effectively forever. haveged ships
# in the live image and is enabled, but make sure it is actually running before
# any keyring work so the gpg key generation always has entropy to draw on.
if ! systemctl is-active --quiet haveged 2>/dev/null; then
    systemctl start haveged 2>/dev/null || haveged -w 1024 2>/dev/null || true
fi

# Make sure the live host keyring is ready so signed packages verify.
if [[ ! -s /etc/pacman.d/gnupg/trustdb.gpg ]]; then
    pacman-key --init
fi
pacman-key --populate archlinux chaotic 2>/dev/null || true

# ---- Detect the local ISO package repo (embedded by build.sh) --------------
LOCAL_REPO=""
ISO_MOUNT="/run/archiso/bootmnt"
if [[ -d "$ISO_MOUNT/neos/pkg" ]] && [[ -n "$(ls -A "$ISO_MOUNT/neos/pkg"/*.pkg.tar.zst 2>/dev/null || true)" ]]; then
    LOCAL_REPO="$ISO_MOUNT/neos/pkg"
    log "found local package repo at $LOCAL_REPO ($(find "$LOCAL_REPO" -name '*.pkg.tar.zst' 2>/dev/null | wc -l) packages)"
fi

# ---- Check network availability (fast timeout for offline detection) -------
NET_AVAILABLE=0
if timeout 5 curl -fsS --max-time 3 -o /dev/null https://geo.mirror.pkgbuild.com/ 2>/dev/null; then
    NET_AVAILABLE=1
    log "network is available — will download latest packages"
else
    log "no network detected"
fi

# ---- Helper: install from local ISO repo (no network needed) --------------
do_offline_install() {
    log "installing ${#PKGS[@]} packages from local ISO repo at $LOCAL_REPO ..."
    TMP_LOCAL=$(mktemp /tmp/neos-pacman-local-XXXXXX)
    # Build a minimal pacman.conf that has the local repo + essential options
    {
        echo "[options]"
        grep -E '^(Architecture|ParallelDownloads|Color|VerbosePkgLists|CheckSpace)' /etc/pacman.conf 2>/dev/null || true
        echo ""
        echo "[neos-local]"
        echo "SigLevel = Optional TrustAll"
        echo "Server = file://${LOCAL_REPO}"
    } > "$TMP_LOCAL"
    pacman -Sy --noconfirm --config "$TMP_LOCAL" 2>/dev/null || true
    pacstrap -K "$ROOT" "${PKGS[@]}" --config "$TMP_LOCAL" || {
        status=$?
        rm -f "$TMP_LOCAL"
        log "offline install failed (exit $status)"
        return "$status"
    }
    rm -f "$TMP_LOCAL"
    log "offline install complete"
}

# ---- Decide: online or offline install? UPFRONT (no mid-install fallback) --
# We choose the mode before touching the target root. This avoids leaving
# the target in a broken state from a partial install.
if [[ -n "$LOCAL_REPO" ]]; then
    # Local repo is available — use aggressive short timeout for network check
    NET_TIMEOUT=3
    NET_RETRIES=2
else
    # No local repo — be more patient waiting for network
    NET_TIMEOUT=5
    NET_RETRIES=12
fi

net_ok=0
if [[ "$NET_AVAILABLE" -eq 1 ]]; then
    log "waiting for network to be fully up ..."
    for _ in $(seq 1 "$NET_RETRIES"); do
        if curl -fsS --max-time "$NET_TIMEOUT" -o /dev/null https://geo.mirror.pkgbuild.com/ 2>/dev/null; then
            net_ok=1
            break
        fi
        sleep 2
    done
fi

if [[ "$net_ok" -eq 1 ]]; then
    # ---- ONLINE: download fresh packages ----------------------------------
    log "online install — downloading latest ${#PKGS[@]} packages from internet..."
    # Build a combined pacman.conf: local repo first (highest priority) when available
    TMP_PACMAN_CONF=$(mktemp /tmp/neos-pacman-conf-XXXXXX)
    trap 'rm -f "$TMP_PACMAN_CONF"' EXIT
    if [[ -n "$LOCAL_REPO" ]]; then
        {
            echo "[neos-local]"
            echo "SigLevel = Optional TrustAll"
            echo "Server = file://${LOCAL_REPO}"
            cat /etc/pacman.conf
        } > "$TMP_PACMAN_CONF"
    else
        cp /etc/pacman.conf "$TMP_PACMAN_CONF"
    fi
    pacman -Sy --noconfirm --config "$TMP_PACMAN_CONF" 2>/dev/null || true
    if ! pacstrap -K "$ROOT" "${PKGS[@]}" --config "$TMP_PACMAN_CONF"; then
        echo "neos-pacstrap: online install failed — check internet connection and retry" >&2
        exit 1
    fi
else
    # ---- OFFLINE: install from local ISO repo ------------------------------
    if [[ -z "$LOCAL_REPO" ]]; then
        echo "neos-pacstrap: no network detected and no local package repo on the ISO." >&2
        echo "neos-pacstrap: connect to the internet and retry the install." >&2
        if [[ "$NET_AVAILABLE" -eq 0 ]]; then
            echo "neos-pacstrap: network check failed immediately (check cable/WiFi)" >&2
        fi
        exit 1
    fi
    do_offline_install || exit 1
fi

# ---- Carry the NeOS repository configuration onto the installed system -----
install -Dm644 /etc/pacman.conf "$ROOT/etc/pacman.conf"
for ml in neos-mirrorlist chaotic-mirrorlist mirrorlist; do
    if [[ -f "/etc/pacman.d/$ml" ]]; then
        install -Dm644 "/etc/pacman.d/$ml" "$ROOT/etc/pacman.d/$ml"
    fi
done

# ---- Apply the NeOS overlay (branding, Plymouth theme, wallpaper, etc.) ----
if [[ -f "$OVERLAY" ]]; then
    log "applying NeOS overlay onto $ROOT ..."
    rsync -a --files-from="$OVERLAY" / "$ROOT/"
else
    echo "neos-pacstrap: WARNING — overlay manifest '$OVERLAY' missing; installed system will lack NeOS branding" >&2
fi

log "base system installed into $ROOT"
