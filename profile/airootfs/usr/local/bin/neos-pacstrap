#!/bin/bash
# neos-pacstrap — NeOS netinstall backend.
#
# Invoked by the Calamares 'pacstrap' step (shellprocess, dontChroot) with the
# target root mount point as $1. Instead of cloning the live squashfs, it
# bootstraps a fresh base system straight from the repos with pacstrap, so the
# installed system is a clean install rather than a copy of the live medium.
#
# This step is where the installer parks the progress bar (~10%) while it pulls
# the whole base over the network, so it MUST NEVER block waiting for something
# that will never come. The three things that can hang it forever are guarded
# below: (1) gpg keyring generation starving for entropy in a VM, (2) pacman
# stopping for an interactive prompt (provider choice / conflict) when there is
# no terminal to answer it, and (3) a not-yet-up network. Each is handled so the
# step either makes progress or fails fast with a clear message — it never hangs.
set -euo pipefail

ROOT="${1:?usage: neos-pacstrap <target-root>}"
PKGLIST="/etc/calamares/neos-packages.txt"
OVERLAY="/etc/calamares/neos-overlay.txt"

log() { echo "neos-pacstrap: $*"; }

if [[ ! -d "$ROOT" ]]; then
    echo "neos-pacstrap: target root '$ROOT' is not a mounted directory" >&2
    exit 1
fi
if [[ ! -f "$PKGLIST" ]]; then
    echo "neos-pacstrap: package list '$PKGLIST' is missing" >&2
    exit 1
fi

# Build the package array (skip comments / blank lines).
mapfile -t PKGS < <(grep -vE '^[[:space:]]*(#|$)' "$PKGLIST")
if [[ ${#PKGS[@]} -eq 0 ]]; then
    echo "neos-pacstrap: package list is empty" >&2
    exit 1
fi

# (1) Entropy: pacstrap -K generates a fresh pacman keyring inside the new root,
# and gpg blocks on /dev/random until the kernel CRNG has enough entropy. On a
# headless VM that can stall for minutes or effectively forever. haveged ships
# in the live image and is enabled, but make sure it is actually running before
# any keyring work so the gpg key generation always has entropy to draw on.
if ! systemctl is-active --quiet haveged 2>/dev/null; then
    systemctl start haveged 2>/dev/null || haveged -w 1024 2>/dev/null || true
fi

# Make sure the live host keyring is ready so signed packages from the NeOS /
# chaotic-aur / garuda repos verify during the bootstrap. The archiso live env
# already initialised this at boot, so only init if the trust db is missing
# (a full re-init is needless entropy/time); populate is cheap and idempotent.
if [[ ! -s /etc/pacman.d/gnupg/trustdb.gpg ]]; then
    pacman-key --init
fi
pacman-key --populate archlinux chaotic 2>/dev/null || true

# (3) Network: bail out fast with a readable message instead of letting pacman
# spin on unreachable mirrors. Wait up to ~60s for the repos to be reachable
# (NetworkManager may still be bringing the link up right after boot).
log "waiting for network ..."
net_ok=0
for _ in $(seq 1 30); do
    if curl -fsS --max-time 5 -o /dev/null https://geo.mirror.pkgbuild.com/ 2>/dev/null \
       || ping -c1 -W2 geo.mirror.pkgbuild.com >/dev/null 2>&1; then
        net_ok=1
        break
    fi
    sleep 2
done
if [[ "$net_ok" -ne 1 ]]; then
    echo "neos-pacstrap: no network after 60s — connect to the internet and retry the install" >&2
    exit 1
fi

# Refresh the package databases up front so pacstrap works from current indexes.
pacman -Sy --noconfirm 2>/dev/null || true

# (2) Non-interactive: pacstrap runs pacman with no controlling terminal here,
# so any prompt (":: Replace X? [Y/n]", provider "Enter a number") would block
# forever. Feed an endless stream of empty lines as stdin so every prompt takes
# its default and the install always proceeds. The same `yes ""` idiom is used
# for mkarchiso in build.sh. Using a process substitution (not a pipe) keeps
# pacstrap's own exit status intact under `set -o pipefail`.
#
# -K bootstraps a fresh, empty pacman keyring inside the new root (the modern
# default for a clean install). pacstrap uses the live host's /etc/pacman.conf,
# which already points at the NeOS mirrors.
log "installing ${#PKGS[@]} packages into $ROOT ..."
pacstrap -K "$ROOT" "${PKGS[@]}" < <(yes "")

# Carry the NeOS repository configuration onto the installed system, otherwise
# the target would inherit only the stock Arch pacman.conf shipped by the
# 'pacman' package and lose chaotic-aur / garuda.
install -Dm644 /etc/pacman.conf "$ROOT/etc/pacman.conf"
for ml in neos-mirrorlist chaotic-mirrorlist mirrorlist; do
    if [[ -f "/etc/pacman.d/$ml" ]]; then
        install -Dm644 "/etc/pacman.d/$ml" "$ROOT/etc/pacman.d/$ml"
    fi
done

# Apply the NeOS overlay (branding, Plymouth theme, wallpaper, hardening,
# custom services …) onto the freshly pacstrapped target. pacstrap only lays
# down packages, so without this the install would be vanilla Arch. The
# manifest lists overlay files relative to /, with the live-/installer-only
# ones already filtered out at build time.
if [[ -f "$OVERLAY" ]]; then
    log "applying NeOS overlay onto $ROOT ..."
    rsync -a --files-from="$OVERLAY" / "$ROOT/"
else
    echo "neos-pacstrap: WARNING — overlay manifest '$OVERLAY' missing; installed system will lack NeOS branding" >&2
fi

log "base system installed into $ROOT"
