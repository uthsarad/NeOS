#!/bin/bash
set -euo pipefail

# Sentinel: [Security] Enforce strict PATH to prevent path hijacking
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# NeOS Driver Manager
# Automatically detects hardware, identifies missing drivers, and provides elite guidance.

echo -e "\e[1m\e[36m🔍 NeOS Hardware Intelligence starting...\e[0m"

# ⚡ Bolt: Cache hardware information to minimize subprocess overhead
if ! command -v lspci &> /dev/null; then
    echo -e "\e[1m\e[31m🚨 pciutils is missing! Hardware detection is disabled.\e[0m"
    exit 1
fi

LSPCI_K_OUT=$(lspci -k || true)
LSUSB_OUT=$(lsusb || true)
PROC_MODULES="$(</proc/modules)"

is_loaded() { [[ "$PROC_MODULES" =~ (^|$'\n')$1[[:space:]] ]]; }

# --- 🖥️ GPU DETECTION ---
printf "\n\e[1m\e[36m🖥️  Graphics Configuration:\e[0m\n"

GPU_BLOCKS=$(echo "$LSPCI_K_OUT" | awk '/VGA|Display|3D/{p=1;print;next} p&&/^[0-9a-f]/{p=0} p')

while IFS= read -r line; do
    if [[ -z "$line" ]]; then continue; fi
    
    if [[ "$line" =~ ^[0-9a-f] ]]; then
        printf "  - \e[1m%s\e[0m\n" "$line"
        
        # Check for drivers
        if [[ "$line" =~ "NVIDIA" ]]; then
            if pacman -Qs nvidia &>/dev/null; then
                echo -e "    \e[32m✅ NVIDIA proprietary drivers are installed.\e[0m"
                is_loaded "nvidia" || { echo "    🚀 Loading modules..."; modprobe -- nvidia nvidia_modeset nvidia_uvm nvidia_drm || true; }
            else
                echo -e "    \e[33m💡 Suggestion:\e[0m Install 'nvidia' for maximum performance."
            fi
        elif [[ "$line" =~ "Intel" ]]; then
            echo -e "    \e[34m🔵 Intel drivers are active.\e[0m"
            is_loaded "i915" || modprobe -- i915 || true
        elif [[ "$line" =~ "AMD" ]] || [[ "$line" =~ "ATI" ]]; then
            echo -e "    \e[31m🔴 AMD/ATI drivers are active.\e[0m"
            is_loaded "amdgpu" || modprobe -- amdgpu || true
        fi
    fi
done <<< "$GPU_BLOCKS"

# --- 🌐 NETWORK DETECTION ---
printf "\n\e[1m\e[36m🌐  Network & Connectivity:\e[0m\n"

# Extract blocks for Network/Ethernet controllers
NET_BLOCKS=$(echo "$LSPCI_K_OUT" | awk '/Network|Ethernet/{p=1;print;next} p&&/^[0-9a-f]/{p=0} p')

# Simple mapping for common missing drivers
declare -A DRIVER_MAP=(
    ["Broadcom"]="broadcom-wl-dkms"
    ["BCM43"]="broadcom-wl-dkms"
    ["RTL8111"]="r8168-dkms"
    ["RTL8168"]="r8168-dkms"
    ["RTL8821CE"]="rtw88-dkms-git"
    ["RTL8822"]="rtw88-dkms-git"
    ["MT7921"]="mt76-dkms-git"
)

while IFS= read -r line; do
    if [[ -z "$line" ]]; then continue; fi
    
    if [[ "$line" =~ ^[0-9a-f] ]]; then
        DEVICE_DESC="${line#*:[0-9a-f][0-9a-f] }"
        printf "  - \e[1m%s\e[0m\n" "$DEVICE_DESC"
        
        # Check if driver is in use
        BLOCK_CONTENT=$(echo "$NET_BLOCKS" | sed -n "/$line/,/^[0-9a-f]/p" | grep "Kernel driver in use" || true)
        
        if [[ -n "$BLOCK_CONTENT" ]]; then
            DRIVER_NAME="${BLOCK_CONTENT#*: }"
            echo -e "    \e[32m✅ Driver in use:\e[0m $DRIVER_NAME"
        else
            echo -e "    \e[31m⚠️  No driver detected!\e[0m"
            
            # Try to suggest a package
            SUGGESTED=false
            for chip in "${!DRIVER_MAP[@]}"; do
                if [[ "$DEVICE_DESC" =~ "$chip" ]]; then
                    echo -e "    \e[36m💡 Recommended Package:\e[0m \e[1m${DRIVER_MAP[$chip]}\e[0m"
                    echo -e "    \e[33m🔧 Action:\e[0m run 'sudo pacman -S ${DRIVER_MAP[$chip]}'"
                    SUGGESTED=true
                    break
                fi
            done
            
            if ! $SUGGESTED; then
                echo -e "    \e[33m💡 Tip:\e[0m Search for drivers based on the device ID shown above."
            fi
        fi
    fi
done <<< "$NET_BLOCKS"

# --- 🧠 CPU & VIRT ---
printf "\n\e[1m\e[36m🧠 System Micro-architecture:\e[0m\n"
CPU_INFO="$(< /proc/cpuinfo)"
if [[ "$CPU_INFO" == *AuthenticAMD* ]]; then
    echo -e "  - AMD CPU detected. Ensuring \e[1mamd-ucode\e[0m is active."
elif [[ "$CPU_INFO" == *GenuineIntel* ]]; then
    echo -e "  - Intel CPU detected. Ensuring \e[1mintel-ucode\e[0m is active."
fi

if VIRT_TYPE=$(systemd-detect-virt 2>/dev/null); then
    echo -e "  - \e[35mVirtualization:\e[0m $VIRT_TYPE detected. Optimizing guest modules..."
    case "$VIRT_TYPE" in
        kvm|qemu) for mod in virtio_pci virtio_blk virtio_net; do is_loaded "$mod" || modprobe -- "$mod" || true; done ;;
        oracle)   for mod in vboxguest vboxsf vboxvideo; do is_loaded "$mod" || modprobe -- "$mod" || true; done ;;
        vmware)   for mod in vmw_balloon vmw_vmci vmwgfx; do is_loaded "$mod" || modprobe -- "$mod" || true; done ;;
    esac
fi

echo -e "\n\e[1m\e[32m✅ NeOS Driver Intelligence check complete.\e[0m"
