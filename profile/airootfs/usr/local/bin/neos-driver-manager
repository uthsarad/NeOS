#!/bin/bash
set -euo pipefail

# Sentinel: [Security] Enforce strict PATH to prevent path hijacking
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# NeOS Driver Manager
# Automatically detects and configures hardware drivers for the best experience.

echo -e "\e[1m\e[36m🔍 NeOS Hardware Detection starting...\e[0m"

# ⚡ Bolt: Use lspci -k for faster module association checks
if ! command -v lspci &> /dev/null; then
    echo -e "\e[1m\e[33m⚠️  pciutils not found, hardware detection may be limited.\e[0m"
fi

# GPU Detection
# Cache lspci output to avoid repeated execution
LSPCI_OUT=$(lspci || true)

# GPU and Network Detection parsed in a single pass using native bash matching
GPU_INFO=""
NET_INFO=""
shopt -s nocasematch
while IFS= read -r line; do
    case "$line" in
        *vga*|*display*|*3d*) GPU_INFO+="$line"$'\n' ;;
        *network*|*ethernet*) NET_INFO+="$line"$'\n' ;;
    esac
done <<< "$LSPCI_OUT"

# Remove trailing newlines
GPU_INFO="${GPU_INFO%$'\n'}"
NET_INFO="${NET_INFO%$'\n'}"

# Bolt: [Performance] Avoided filtering lspci output directly with regex or grep to save subprocess overhead.
# Palette: [UX] Format multi-line graphics string variable with bullet points for readability
echo -e "\e[1m\e[36m🖥️  Detected Graphics:\e[0m"
while IFS= read -r line; do
    if [[ -n "$line" ]]; then
        echo "  - $line"
    fi
done <<< "$GPU_INFO"

if [[ "$GPU_INFO" == *nvidia* ]]; then
    echo -e "\e[1m\e[32m🎮 NVIDIA GPU detected!\e[0m"
    # Check if proprietary drivers are already installed (they should be in packages.x86_64)
    if pacman -Qs nvidia &> /dev/null; then
        echo -e "\e[1m\e[32m✅ NVIDIA proprietary drivers are present.\e[0m"
        # Sentinel: Ensure kernel modules are loaded safely
        # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
        if ! grep -q "^nvidia " /proc/modules; then
            echo -e "\e[1m\e[34m🚀 Loading NVIDIA kernel modules...\e[0m"
            modprobe nvidia nvidia_modeset nvidia_uvm nvidia_drm || echo -e "\e[1m\e[31m❌ Failed to load NVIDIA modules.\e[0m"
        fi
    else
        echo -e "\e[1m\e[33m💡 Suggestion:\e[0m Install 'nvidia' and 'nvidia-utils' for optimal performance."
    fi
elif [[ "$GPU_INFO" == *intel* ]]; then
    echo -e "\e[1m\e[34m🔵 Intel Graphics detected.\e[0m"
    # Ensure i915 is loaded
    # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
    grep -q "^i915 " /proc/modules || modprobe i915 || true
elif [[ "$GPU_INFO" == *amd* ]] || [[ "$GPU_INFO" == *ati* ]]; then
    echo -e "\e[1m\e[31m🔴 AMD/ATI Graphics detected.\e[0m"
    # Ensure amdgpu is loaded
    # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
    grep -q "^amdgpu " /proc/modules || modprobe amdgpu || true
fi

# Network Detection
# Bolt: [Performance] Optimized lspci parsing for network controllers to reduce command execution overhead.
# Sentinel: [Security] Audit network detection regex for potential injection or parsing vulnerabilities.
# Palette: [UX] Format multi-line network string variable with bullet points for readability
echo -e "\e[1m\e[36m🌐  Detected Network:\e[0m"
while IFS= read -r line; do
    if [[ -n "$line" ]]; then
        echo "  - $line"
    fi
done <<< "$NET_INFO"

if [[ "$NET_INFO" == *broadcom* ]] || [[ "$NET_INFO" == *bcm* ]]; then
    echo -e "\e[1m\e[36m📶 Broadcom network detected.\e[0m Ensuring broadcom-wl is available..."
    # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
    grep -q "^wl " /proc/modules || modprobe wl || true
elif [[ "$NET_INFO" == *realtek* ]] || [[ "$NET_INFO" == *rtl* ]]; then
    echo -e "\e[1m\e[36m📶 Realtek network detected.\e[0m"
    # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
    grep -q "^r8169 " /proc/modules || modprobe r8169 || true
elif [[ "$NET_INFO" == *intel* ]]; then
    echo -e "\e[1m\e[36m📶 Intel network detected.\e[0m"
    # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
    grep -q "^iwlwifi " /proc/modules || modprobe iwlwifi || true
fi
shopt -u nocasematch

# CPU Microcode
CPU_INFO=$(grep -m1 "vendor_id" /proc/cpuinfo || true)
if [[ "$CPU_INFO" == *AuthenticAMD* ]]; then
    echo -e "\e[1m\e[32m🧠 AMD CPU detected.\e[0m Ensuring amd-ucode is available..."
elif [[ "$CPU_INFO" == *GenuineIntel* ]]; then
    echo -e "\e[1m\e[34m🧠 Intel CPU detected.\e[0m Ensuring intel-ucode is available..."
fi

# Virtualization Guest Support
if systemd-detect-virt -q; then
    VIRT_TYPE=$(systemd-detect-virt)
    printf "\e[1m\e[35m☁️  Virtualization detected:\e[0m %s\n" "$VIRT_TYPE"
    case "$VIRT_TYPE" in
        kvm|qemu)
            echo -e "\e[1m\e[36m🔧 Loading QEMU/KVM guest modules...\e[0m"
            # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
            for mod in virtio_pci virtio_blk virtio_net virtio_balloon; do
                grep -q "^${mod/_/-} " /proc/modules || modprobe "$mod" || true
            done
            ;;
        oracle)
            echo -e "\e[1m\e[36m🔧 Loading VirtualBox guest modules...\e[0m"
            # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
            for mod in vboxguest vboxsf vboxvideo; do
                grep -q "^${mod/_/-} " /proc/modules || modprobe "$mod" || true
            done
            ;;
        vmware)
            echo -e "\e[1m\e[36m🔧 Loading VMware guest modules...\e[0m"
            # Bolt: [Performance] Avoid unconditional modprobe subshells. Use /proc/modules native grep.
            for mod in vmw_balloon vmw_vmci vmwgfx; do
                grep -q "^${mod/_/-} " /proc/modules || modprobe "$mod" || true
            done
            ;;
    esac
fi

echo -e "\e[1m\e[32m✅ NeOS Driver Management task completed.\e[0m"
